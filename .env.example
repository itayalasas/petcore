# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Multi-tenant Subdomain Configuration
# Set to 'true' to enable subdomain-based tenancy (requires DNS configuration)
# In development, keep this as 'false' to use context-based tenancy
VITE_ENABLE_SUBDOMAIN_TENANCY=false

# Your base domain (only used when VITE_ENABLE_SUBDOMAIN_TENANCY=true)
# Example: myapp.com (tenants will be accessed via tenant-slug.myapp.com)
# For local development: localhost:5173
VITE_BASE_DOMAIN=localhost:5173
